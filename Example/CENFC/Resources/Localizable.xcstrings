    "Access conditions per MIFARE Classic datasheet. Bytes 6-8 of the sector trailer encode permissions for all 4 blocks using C1/C2/C3 bits with complement verification." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Access conditions per MIFARE Classic datasheet. Bytes 6-8 of the sector trailer encode permissions for all 4 blocks using C1/C2/C3 bits with complement verification."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "根据 MIFARE Classic 数据手册定义的访问条件。扇区尾部的第 6-8 字节使用 C1/C2/C3 位及其补码校验来编码全部 4 个块的权限。"
          }
        }
      }
    },

    "The app captured enough transport metadata to classify the tag family, but not enough to start a robust dump routine." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The app captured enough transport metadata to classify the tag family, but not enough to start a robust dump routine."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "应用已采集到足够的传输元数据来分类标签系列，但不足以启动完整的转储流程。"
          }
        }
      }
    },
    "The chip exposes itself as ISO 14443-4 and then enters an ICAO 9303 passport workflow." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The chip exposes itself as ISO 14443-4 and then enters an ICAO 9303 passport workflow."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "芯片以 ISO 14443-4 方式展现，然后进入 ICAO 9303 护照工作流程。"
          }
        }
      }
    },
    "The demo identified the tag and attempted the family-specific dump routine, but did not finish cleanly." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The demo identified the tag and attempted the family-specific dump routine, but did not finish cleanly."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "示例已识别标签并尝试了系列专属转储流程，但未能完整完成。"
          }
        }
      }
    },
    "The demo issued family-specific probes so coarse tag identification could be narrowed to a concrete product family." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The demo issued family-specific probes so coarse tag identification could be narrowed to a concrete product family."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "示例发送了系列专属探测命令，将粗略的标签识别缩小到具体的产品系列。"
          }
        }
      }
    },
    "The demo reached the DESFire file enumeration phase, but a file operation or permission boundary stopped the dump." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The demo reached the DESFire file enumeration phase, but a file operation or permission boundary stopped the dump."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "示例已进入 DESFire 文件枚举阶段，但文件操作或权限限制导致转储停止。"
          }
        }
      }
    },
    "The demo reached the FeliCa probing phase, but a block or service read failed before the snapshot finished." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The demo reached the FeliCa probing phase, but a block or service read failed before the snapshot finished."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "示例已进入 FeliCa 探测阶段，但在快照完成前块或服务读取失败。"
          }
        }
      }
    },
    "The demo reached the ISO 15693 block-read phase, but a block or security-status read failed before the dump finished." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The demo reached the ISO 15693 block-read phase, but a block or security-status read failed before the dump finished."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "示例已进入 ISO 15693 块读取阶段，但在转储完成前块或安全状态读取失败。"
          }
        }
      }
    },
    "The demo reached the Type 2 read phase, but an Ultralight C protection boundary or page read failure stopped the snapshot." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The demo reached the Type 2 read phase, but an Ultralight C protection boundary or page read failure stopped the snapshot."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "示例已进入 Type 2 读取阶段，但 Ultralight C 保护边界或页面读取失败导致快照停止。"
          }
        }
      }
    },
    "The demo reached the Type 2 read phase, but one of the page reads failed before a stable dump could be saved." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The demo reached the Type 2 read phase, but one of the page reads failed before a stable dump could be saved."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "示例已进入 Type 2 读取阶段，但在保存稳定转储前某个页面读取失败。"
          }
        }
      }
    },
    "The demo reached the Type 4 file-selection phase, but an ISO 7816 APDU or file access boundary stopped the dump." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
